generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED
}

enum Frequency {
  MONTHLY
  WEEKLY
}

enum OccurrenceStatus {
  CONFIRMED
  SKIPPED
}

model User {
  id        String   @id // matches Supabase Auth user id
  email     String   @unique
  createdAt DateTime @default(now())

  accounts        Account[]
  cycleConfigs    CycleConfig[]
  financeCycles   FinanceCycle[]
  categories      Category[]
  transactions    Transaction[]
  budgetTemplates BudgetTemplate[]
  goals           Goal[]
  profile         Profile?
  recurring       RecurringTransaction[]
  insightCaches   InsightCache[]
}

model Profile {
  id          String @id @default(cuid())
  userId      String @unique
  fullName    String
  nickname    String
  avatarEmoji String @default("🙂")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id             String   @id @default(cuid())
  userId         String
  name           String
  icon           String?
  color          String?
  openingBalance Decimal  @default(0) @db.Decimal(14, 2)
  createdAt      DateTime @default(now())

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[] @relation("SourceAccount")
  incomingTransactions Transaction[] @relation("DestinationAccount")

  @@index([userId])
}

/// One row per cycle-config change. Active config = latest where effectiveFrom <= now.
/// effectiveFrom MUST be a cycle boundary — see ADR 0001.
model CycleConfig {
  id            String   @id @default(cuid())
  userId        String
  startDay      Int // 1..28
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycles FinanceCycle[]

  @@index([userId, effectiveFrom])
}

model FinanceCycle {
  id            String   @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime // exclusive
  cycleConfigId String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleConfig  CycleConfig   @relation(fields: [cycleConfigId], references: [id])
  transactions Transaction[]
  cycleBudgets CycleBudget[]
  goals        Goal[]

  @@unique([userId, startDate])
  @@index([userId])
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  isDefault Boolean @default(false)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  budgetTemplates BudgetTemplate[]
  cycleBudgets    CycleBudget[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id                   String          @id @default(cuid())
  userId               String
  cycleId              String
  type                 TransactionType
  amount               Decimal         @db.Decimal(14, 2)
  date                 DateTime
  notes                String?
  categoryId           String?
  accountId            String // source for EXPENSE/TRANSFER, destination for INCOME
  destinationAccountId String? // TRANSFER only
  receiptPath          String? // Supabase Storage object key for an attached receipt
  createdAt            DateTime        @default(now())

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle              FinanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category           Category?    @relation(fields: [categoryId], references: [id])
  account            Account      @relation("SourceAccount", fields: [accountId], references: [id])
  destinationAccount Account?     @relation("DestinationAccount", fields: [destinationAccountId], references: [id])

  @@index([userId, cycleId])
  @@index([userId, cycleId, date, id])
  @@index([userId, cycleId, type, categoryId])
  @@index([userId, accountId, date, id])
  @@index([userId, destinationAccountId, date, id])
  @@index([userId, type, date])
  @@index([accountId])
}

/// Persistent budget per category. Carries forward across cycles.
model BudgetTemplate {
  id         String  @id @default(cuid())
  userId     String
  categoryId String
  amountLkr  Decimal @db.Decimal(14, 2)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

/// Materialised budget for a specific cycle. isOverride = manually changed for this cycle.
model CycleBudget {
  id         String  @id @default(cuid())
  cycleId    String
  categoryId String
  amountLkr  Decimal @db.Decimal(14, 2)
  isOverride Boolean @default(false)

  cycle    FinanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([cycleId, categoryId])
}

/// A template for a transaction expected to repeat. Never posts automatically —
/// occurrences surface as confirm-to-post Due Occurrences (see CONTEXT.md).
model RecurringTransaction {
  id                   String          @id @default(cuid())
  userId               String
  type                 TransactionType
  amount               Decimal         @db.Decimal(14, 2)
  accountId            String
  destinationAccountId String?
  categoryId           String?
  notes                String?
  frequency            Frequency
  dayOfMonth           Int? // 1..28 for MONTHLY
  weekday              Int? // 0..6 for WEEKLY
  anchorDate           DateTime
  active               Boolean         @default(true)
  createdAt            DateTime        @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurrences RecurringOccurrence[]

  @@index([userId])
}

/// Ledger of handled occurrences (confirmed or skipped) for dedupe / no-double-post.
model RecurringOccurrence {
  id                     String           @id @default(cuid())
  recurringTransactionId String
  dueDate                DateTime
  status                 OccurrenceStatus
  postedTransactionId    String? // set when CONFIRMED
  createdAt              DateTime         @default(now())

  recurring RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)

  @@unique([recurringTransactionId, dueDate])
}

/// Cached Smart Insight prose per cycle (ADR 0002). Stores source facts + prose.
model InsightCache {
  id        String   @id @default(cuid())
  userId    String
  cycleId   String
  facts     Json
  lines     Json // string[] of phrased sentences
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cycleId])
}

model Goal {
  id                String     @id @default(cuid())
  userId            String
  cycleId           String
  name              String
  targetAmountLkr   Decimal    @db.Decimal(14, 2)
  achievedAmountLkr Decimal    @default(0) @db.Decimal(14, 2)
  status            GoalStatus @default(ACTIVE)
  createdAt         DateTime   @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle FinanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([userId, cycleId])
}
