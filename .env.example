# ─────────────────────────────────────────────────────────────────────────
# Database — Supabase Postgres. The right pooler depends on the RUNTIME.
# See docs/adr/0003 for the full reasoning.
# ─────────────────────────────────────────────────────────────────────────

# LOCAL DEV (long-running `next dev`/`next start`, especially far from the DB
# region): use the SESSION pooler (port 5432). Fewer round-trips, much faster
# per query over distance. Keep a small connection_limit (session pooler caps
# at ~15 total connections).
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?connection_limit=5"

# VERCEL / SERVERLESS (MULTI-USER PRODUCTION): override DATABASE_URL in the
# Vercel dashboard to the TRANSACTION pooler (port 6543, pgbouncer=true,
# connection_limit=1). Serverless opens many short-lived connections; the
# transaction pooler is built for that and avoids exhausting the session cap.
# Intra-region (Vercel syd1 ↔ Supabase Sydney) it is also fast.
#   DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations always use the direct/session connection (port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────
# Supabase Auth (Google OAuth) — public, safe to expose to the browser.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# ─────────────────────────────────────────────────────────────────────────
# Smart Insights (optional). Without it, insights fall back to plain wording
# (ADR 0002). Generation is manual (user taps Generate) and cached per cycle.
# ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
